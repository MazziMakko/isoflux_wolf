# Database (Supabase → Settings → Database → Connection string)
# Used by Prisma for migrations and direct database access
DATABASE_URL=postgresql://postgres.qmctxtmmzeutlgegjrnb:IsoFlux@856$@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.qmctxtmmzeutlgegjrnb:IsoFlux@856$@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# Stripe (Dashboard → Developers → API keys / Webhooks)
# IMPORTANT: Use LIVE keys in production (sk_live_*, pk_live_*, whsec_*)
STRIPE_SECRET_KEY=sk_live_your_live_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_live_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_live_webhook_secret_here
STRIPE_PRICE_PRO=price_your_pro_price_id_here

# Security (generate: openssl rand -base64 32 or openssl rand -hex 32)
# CRITICAL: Generate new secrets for production, do not use dev values
JWT_SECRET=GENERATE_NEW_32_CHAR_SECRET_FOR_PRODUCTION
ENCRYPTION_KEY=GENERATE_NEW_32_CHAR_SECRET_FOR_PRODUCTION
CRON_SECRET=GENERATE_NEW_32_CHAR_SECRET_FOR_PRODUCTION

# =====================================================
# RESEND: EMAIL OUTREACH (WOLF HUNTER)
# =====================================================

# Resend API Key (get from: https://resend.com/api-keys)
# REQUIRED for Hunter Engine email outreach
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=wolf@isoflux.app

# =====================================================
# HUNTER ENGINE: AI-POWERED LEAD SCORING
# =====================================================

# Ollama (Local LLM) - For production, consider remote Ollama deployment
OLLAMA_API_URL=http://your-ollama-server:11434
OLLAMA_MODEL=llama3.2

# AI Lead Scoring Configuration
AI_SCORING_ENABLED=true
AI_SCORING_MAX_RETRIES=3
AI_SCORING_TIMEOUT_MS=30000

# Alternative: OpenAI API (paid, for production if preferred over Ollama)
# OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# Alternative: Google Gemini API (paid, for production if preferred)
# GEMINI_API_KEY=your_gemini_api_key_here

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# =====================================================
# WOLF SHIELD: HUD-SPECIFIC CONFIGURATION
# =====================================================

# Wolf Shield Settings
WOLF_SHIELD_ENABLED=true
LEDGER_AUTO_VERIFY=true
COMPLIANCE_HEALTH_THRESHOLD=70

# HUD Compliance
HUD_CERTIFICATION_REQUIRED=true
DEFAULT_ACCOUNTING_PERIOD_CLOSE_DAY=5
RECERTIFICATION_WARNING_DAYS=30

# Role-Based Access Control
SUPER_ADMIN_EMAIL=thenationofmazzi@gmail.com
DEFAULT_TRIAL_DAYS=30
SUBSCRIPTION_GRACE_PERIOD_DAYS=7

# Ledger Configuration
LEDGER_HASH_ALGORITHM=SHA256
LEDGER_CHAIN_VERIFICATION_ON_INSERT=true
LEDGER_MAX_DESCRIPTION_LENGTH=500

# Realtime Updates
REALTIME_ENABLED=true
REALTIME_LEDGER_CHANNEL_PREFIX=ledger
REALTIME_SUBSCRIPTION_CHANNEL_PREFIX=subscription

# Security: Ledger Immutability (NEVER CHANGE IN PRODUCTION)
ALLOW_LEDGER_DELETE=false
ALLOW_LEDGER_UPDATE=false
ENFORCE_PERIOD_CLOSURE=true

# Audit & Logging
AUDIT_LOG_ENABLED=true
AUDIT_RETENTION_DAYS=2555

# =====================================================
# OPTIONAL: MONITORING & ANALYTICS
# =====================================================

# Sentry Error Tracking
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Google Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# SMTP (Optional - if using custom email server)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# Webhooks (Optional)
# MERCURY_WEBHOOK_SECRET=your_mercury_webhook_secret
# FLUTTERWAVE_SECRET_HASH=your_flutterwave_secret_hash

# =====================================================
# DEPLOYMENT NOTES
# =====================================================
# 
# 1. Set all variables in Vercel Dashboard → Environment Variables
# 2. Generate new secrets for JWT_SECRET, ENCRYPTION_KEY, CRON_SECRET
# 3. Use Stripe LIVE keys (sk_live_*, pk_live_*)
# 4. Verify domain in Resend before setting RESEND_FROM_EMAIL
# 5. Deploy Ollama to remote server or use OpenAI API for production
# 6. Never commit this file with real values
# 
# Commands:
# - Generate secrets: openssl rand -hex 32
# - Test env vars: vercel env pull .env.production.local
# - Deploy: git push origin main (auto-deploys to Vercel)
